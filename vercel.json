{
  "functions": {
    "api/*.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/checkout",
      "destination": "/api/checkout.mjs"
    },
    {
      "source": "/api/webhook",
      "destination": "/api/webhook.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
